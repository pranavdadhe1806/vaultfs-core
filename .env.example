# ===========================================
# VaultFS Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The app runs fine WITHOUT a .env file — you'll
# just log in as Guest. OAuth and Firestore sync
# require valid credentials below.
# ===========================================

# --- Google OAuth 2.0 ---
# Get these from: https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application)
# Add redirect URI: http://localhost:9000/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth ---
# Get these from: https://github.com/settings/developers
# Create a new OAuth App
# Set callback URL: http://localhost:9000/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Firestore Sync (Optional) ---
# Firebase project ID (defaults to "vault-fs" if not set)
FIREBASE_PROJECT_ID=

# Path to your Google Cloud service account JSON key file.
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Or set the GOOGLE_APPLICATION_CREDENTIALS system env variable instead.
GOOGLE_APPLICATION_CREDENTIALS=
